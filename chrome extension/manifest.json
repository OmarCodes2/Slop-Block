{
  "manifest_version": 3,
  "name": "Slop Block",
  "version": "1.0.0",
  "description": "Filters LinkedIn feed to show only recruiter hiring posts with hybrid classification (local heuristics + AI).",
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/feed/*",
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/content/blocking/postState.js",
        "src/content/posts/postText.js",
        "src/content/posts/postIdentity.js",
        "src/content/posts/postMetadata.js",
        "src/content/classification/categoryConfig.js",
        "src/content/classification/ruleOrder.js",
        "src/content/classification/classifyPost.js",
        "src/content/blocking/shouldBlockPost.js",
        "src/content/overlay/renderOverlay.js",
        "src/content/overlay/updateOverlay.js",
        "src/content/overlay/removeOverlay.js",
        "src/content/ai/aiLabelClient.js",
        "src/content/observer/postDiscovery.js",
        "src/content/observer/feedObserver.js",
        "src/content/observer/navigationWatcher.js",
        "src/content/index.js"
      ],
      "css": [
        "src/content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Slop Block"
  }
}
